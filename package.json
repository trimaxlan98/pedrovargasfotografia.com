{
  "name": "fotografia-profesional",
  "private": true,
  "version": "1.1.2.4",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm run dev --prefix server",
    "build": "npx tsc -b && npx vite build",
    "build:all": "npm run build && npm run build --prefix server",
    "postinstall": "npx vite build && npx prisma generate --schema=server/prisma/schema.prisma && DATABASE_URL=file:./server/prisma/dev.db npx prisma migrate deploy --schema=server/prisma/schema.prisma",
    "start": "node server/dist/server.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "framer-motion": "^12.4.7",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.475.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.12",
    "postcss": "^8.5.1",
    "prisma": "^5.10.2",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "uuid": "^9.0.1",
    "vite": "^6.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript-eslint": "^8.22.0"
  }
}
